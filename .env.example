# ============================================================
#  Gemini Cloud Sentinel — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ============================================================

# ─── Gemini AI ───────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── GitHub ──────────────────────────────────────────────────
# Create a PAT at: https://github.com/settings/tokens
# Required scopes: repo, workflow, pull_requests
GITHUB_TOKEN=your_github_personal_access_token_here

# The repository the sentinel monitors (format: owner/repo)
GITHUB_REPOSITORY=your_github_username/CloudWatchtower

# ─── Azure (for context-aware analysis) ──────────────────────
# Create a Service Principal:
#   az ad sp create-for-rbac --name "gemini-sentinel" --role "Reader" \
#     --scopes /subscriptions/<your-subscription-id>
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id

# ─── MCP Server ──────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# ─── Sentinel Behaviour ──────────────────────────────────────
# Minimum severity to flag in PR comments: low | medium | high | critical
SENTINEL_MIN_SEVERITY=medium

# Auto-create remediation PRs when pipeline fails: true | false
SENTINEL_AUTO_REMEDIATE=true
